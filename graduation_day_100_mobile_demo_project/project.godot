; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="毕业后的第100天"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7")

[autoload]

GameState="*res://scripts/autoload/GameState.gd"
ActionManager="*res://scripts/autoload/ActionManager.gd"
EventManager="*res://scripts/autoload/EventManager.gd"
LocationManager="*res://scripts/autoload/LocationManager.gd"
EndingManager="*res://scripts/autoload/EndingManager.gd"
SaveManager="*res://scripts/autoload/SaveManager.gd"
DayManager="*res://scripts/autoload/DayManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
